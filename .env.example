# ─── Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values.

# Database (PostgreSQL) – falls back to SQLite if unavailable
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cricket_ads
DB_USER=postgres
DB_PASSWORD=postgres

# Video processing
FRAME_RATE=1.0

# YOLO model (auto-downloaded on first run)
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.35

# OpenAI (optional – leave blank for fallback keyword search)
OPENAI_API_KEY=
LLM_MODEL=gpt-3.5-turbo

# AWS S3 (optional – leave blank for local storage)
S3_BUCKET=
S3_PREFIX=jio-hotstar
AWS_REGION=ap-south-1
